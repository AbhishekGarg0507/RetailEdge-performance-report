              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Customer ID] &#10;END' />
            </column>
            <column caption='CY Sales per Customer' datatype='real' name='[Calculation_243968463958102030]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_1075445540639485955]) / COUNTD([Calculation_243968463930339328])' />
            </column>
            <column caption='PY Sales per Customer' datatype='real' name='[Calculation_243968463958179855]' role='measure' type='quantitative'>
